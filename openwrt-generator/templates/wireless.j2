config wifi-device 'radio0'
    option type 'mac80211'
    option channel '{{ channel }}'
    option hwmode '11g'
    option path 'platform/ahb/18100000.wmac'
    option country 'US'
    option txpower '20'

config wifi-iface 'mesh0'
    option device 'radio0'
    option mode 'mesh'
    option mesh_id '{{ mesh_id }}'
    option encryption 'psk2'
    option key '{{ mesh_key }}'
    option network 'wlan'